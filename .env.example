DATABASE_URL="file:./dev.db"

# Public deployment example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# local: save uploaded files under public/uploads.
# cloudinary: upload files to Cloudinary.
# url-only: disable direct file upload and use photoUrl fields.
IMAGE_STORAGE_PROVIDER="local"

# Required only when IMAGE_STORAGE_PROVIDER="cloudinary".
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET=""
CLOUDINARY_FOLDER="duel-binder/owned-cards"
